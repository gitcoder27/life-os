NODE_ENV=development
HOST=0.0.0.0
PORT=3004
APP_ORIGIN=http://localhost:5174
# Defaults for local development use .env.development.
# Set NODE_ENV=production (or ENV_FILE=./.env.production) for the production DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/life_os_dev
DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/life_os_dev
PROD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/life_os
SESSION_COOKIE_NAME=life_os_session
SESSION_SECRET=change-me-before-production
SESSION_TTL_DAYS=14
CSRF_COOKIE_NAME=life_os_csrf
DATABASE_SEPARATION_STRICT=false
AUTO_APPLY_MIGRATIONS=false
AUTO_CREATE_DATABASE=false
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-please
OWNER_DISPLAY_NAME=Owner
