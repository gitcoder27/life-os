{
  "name": "life-os-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "dev:worker": "NODE_ENV=development tsx watch src/jobs/worker.ts",
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run prisma:generate",
    "start": "NODE_ENV=production node dist/index.js",
    "worker": "NODE_ENV=production node dist/jobs/worker.js",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@life-os/contracts": "file:../packages/contracts",
    "@prisma/client": "^6.5.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "^6.5.0",
    "vitest": "^3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
