generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum GoalDomain {
  HEALTH
  MONEY
  WORK_GROWTH
  HOME_ADMIN
  DISCIPLINE
  OTHER
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum PlanningCycleType {
  DAY
  WEEK
  MONTH
}

enum PlanningCycleStatus {
  OPEN
  REVIEW_READY
  CLOSED
}

enum PriorityStatus {
  PENDING
  COMPLETED
  DROPPED
}

enum TaskStatus {
  PENDING
  COMPLETED
  DROPPED
}

enum TaskOriginType {
  MANUAL
  QUICK_CAPTURE
  CARRY_FORWARD
  REVIEW_SEED
  RECURRING
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CheckinStatus {
  COMPLETED
  SKIPPED
}

enum RoutinePeriod {
  MORNING
  EVENING
}

enum WorkoutStatus {
  NOT_LOGGED
  PLANNED
  DONE
  MISSED
}

enum ReviewType {
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationTone {
  INFO
  WARNING
  URGENT
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String
  displayName    String?
  status         UserStatus         @default(ACTIVE)
  onboardedAt    DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  sessions       Session[]
  preferences    UserPreference?
  goals          Goal[]
  planningCycles PlanningCycle[]
  tasks          Task[]
  habits         Habit[]
  routines       Routine[]
  categories     ExpenseCategory[]
  expenses       Expense[]
  notifications  Notification[]
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  sessionTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  lastSeenAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditEvent {
  id           String   @id @default(uuid())
  userId       String?
  eventType    String
  payload      Json
  createdAt    DateTime @default(now())
}

model UserPreference {
  userId                String   @id
  timezone              String   @default("UTC")
  currencyCode          String   @default("USD")
  weekStartsOn          Int      @default(1)
  dailyReviewStartTime  String?
  dailyReviewEndTime    String?
  dailyWaterTargetMl    Int      @default(2500)
  scoringEnabled        Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String      @id @default(uuid())
  userId      String
  title       String
  domain      GoalDomain
  status      GoalStatus  @default(ACTIVE)
  targetDate  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  priorities  CyclePriority[]
  tasks       Task[]
}

model PlanningCycle {
  id             String              @id @default(uuid())
  userId         String
  cycleType      PlanningCycleType
  cycleStartDate DateTime
  cycleEndDate   DateTime
  status         PlanningCycleStatus @default(OPEN)
  theme          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  priorities     CyclePriority[]

  @@unique([userId, cycleType, cycleStartDate])
}

model CyclePriority {
  id               String         @id @default(uuid())
  planningCycleId  String
  slot             Int
  title            String
  status           PriorityStatus @default(PENDING)
  goalId           String?
  sourceReviewType ReviewType?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  planningCycle    PlanningCycle  @relation(fields: [planningCycleId], references: [id], onDelete: Cascade)
  goal             Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@unique([planningCycleId, slot])
}

model Task {
  id                String         @id @default(uuid())
  userId            String
  title             String
  notes             String?
  status            TaskStatus     @default(PENDING)
  scheduledForDate  DateTime?
  dueAt             DateTime?
  goalId            String?
  originType        TaskOriginType @default(MANUAL)
  carriedFromTaskId String?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal              Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

model Habit {
  id               String         @id @default(uuid())
  userId           String
  title            String
  category         String?
  scheduleRuleJson Json
  targetPerDay     Int            @default(1)
  status           HabitStatus    @default(ACTIVE)
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkins         HabitCheckin[]
}

model HabitCheckin {
  id          String        @id @default(uuid())
  habitId      String
  occurredOn   DateTime
  status       CheckinStatus @default(COMPLETED)
  source       String        @default("tap")
  note         String?
  completedAt  DateTime?
  habit        Habit         @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, occurredOn])
}

model Routine {
  id         String        @id @default(uuid())
  userId     String
  name       String
  period     RoutinePeriod
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      RoutineItem[]
}

model RoutineItem {
  id         String               @id @default(uuid())
  routineId  String
  title      String
  sortOrder  Int
  isRequired Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  routine    Routine              @relation(fields: [routineId], references: [id], onDelete: Cascade)
  checkins   RoutineItemCheckin[]
}

model RoutineItemCheckin {
  id            String      @id @default(uuid())
  routineItemId String
  occurredOn    DateTime
  completedAt   DateTime?
  routineItem   RoutineItem @relation(fields: [routineItemId], references: [id], onDelete: Cascade)

  @@unique([routineItemId, occurredOn])
}

model WaterLog {
  id         String   @id @default(uuid())
  userId     String
  amountMl   Int
  occurredAt DateTime
  createdAt  DateTime @default(now())
}

model MealLog {
  id         String   @id @default(uuid())
  userId     String
  label      String
  occurredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
}

model WorkoutDay {
  id          String        @id @default(uuid())
  userId      String
  workoutDate DateTime
  status      WorkoutStatus @default(NOT_LOGGED)
  notes       String?
  updatedAt   DateTime      @updatedAt

  @@unique([userId, workoutDate])
}

model WeightLog {
  id         String   @id @default(uuid())
  userId     String
  weightKg   Decimal  @db.Decimal(5, 2)
  occurredAt DateTime
  createdAt  DateTime @default(now())
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@unique([userId, name])
}

model RecurringExpense {
  id               String   @id @default(uuid())
  userId           String
  expenseCategoryId String?
  title            String
  amount           Decimal  @db.Decimal(12, 2)
  dueDayOfMonth    Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Expense {
  id               String           @id @default(uuid())
  userId           String
  expenseCategoryId String?
  title            String
  amount           Decimal          @db.Decimal(12, 2)
  occurredAt       DateTime
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
}

model DailyReview {
  id              String   @id @default(uuid())
  userId          String
  reviewDate      DateTime
  wins            Json
  misses          Json
  tomorrowFocus   Json
  submittedAt     DateTime @default(now())

  @@unique([userId, reviewDate])
}

model WeeklyReview {
  id                String   @id @default(uuid())
  userId            String
  weekStartDate     DateTime
  summary           Json
  nextWeekFocus     Json
  submittedAt       DateTime @default(now())

  @@unique([userId, weekStartDate])
}

model MonthlyReview {
  id                String   @id @default(uuid())
  userId            String
  monthStartDate    DateTime
  summary           Json
  nextMonthFocus    Json
  submittedAt       DateTime @default(now())

  @@unique([userId, monthStartDate])
}

model DailyScore {
  id             String   @id @default(uuid())
  userId         String
  scoreDate      DateTime
  value          Int
  earnedPoints   Int
  possiblePoints Int
  label          String
  breakdown      Json
  finalisedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, scoreDate])
}

model Notification {
  id          String             @id @default(uuid())
  userId      String
  title       String
  body        String
  tone        NotificationTone   @default(INFO)
  status      NotificationStatus @default(UNREAD)
  visibleFrom DateTime?
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}
