[Unit]
Description=Life OS worker (%i)
After=network.target docker.service
Wants=docker.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/life-os-prod/server
EnvironmentFile=/home/ubuntu/apps/life-os-prod/server/.env.production
ExecStart=/usr/bin/npm run worker -- --schedule %i
