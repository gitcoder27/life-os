[Unit]
Description=Life OS PostgreSQL backup
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/life-os-prod
EnvironmentFile=/home/ubuntu/apps/life-os-prod/server/.env.production
EnvironmentFile=-/etc/life-os/backup.env
Environment=BACKUP_DIR=/var/backups/life-os/postgres
Environment=BACKUP_RETENTION_DAYS=14
ExecStart=/home/ubuntu/apps/life-os-prod/deploy/scripts/life-os-postgres-backup.sh
