{
  "name": "life-os",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "packages/contracts"
  ],
  "scripts": {
    "build": "npm run build:contracts && npm run build:server && npm run build:client",
    "typecheck": "npm run typecheck:contracts && npm run typecheck:server && npm run typecheck:client",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build:contracts": "npm run build -w packages/contracts",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "typecheck:contracts": "npm run typecheck -w packages/contracts",
    "typecheck:client": "npm run typecheck -w client",
    "typecheck:server": "npm run typecheck -w server"
  }
}
